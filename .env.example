# Local: copy to `.env.local` (recommended) or `.env`. Do not commit real secrets.

# =============================================================================
# LLM API keys (at least one of GEMINI/GOOGLE or ANTHROPIC required for Copilot)
# =============================================================================
# GEMINI_API_KEY: Used by Vite (injected for the client bundle) and the Express server.
GEMINI_API_KEY=

# GOOGLE_API_KEY: Alternate name for the same Gemini key (server only).
GOOGLE_API_KEY=

# LLM_PROVIDER: gemini | anthropic | openrouter — drives /api/llm/*; Copilot supports gemini or anthropic.
LLM_PROVIDER=gemini

# ANTHROPIC_API_KEY: Claude for Copilot (when LLM_PROVIDER=anthropic) and /api/llm.
ANTHROPIC_API_KEY=

# OPENROUTER_API_KEY: OpenAI-compatible /api/llm only (not used by Copilot BuiltInAgent).
OPENROUTER_API_KEY=

# =============================================================================
# Model IDs (optional; defaults match server/src/llm/complete.ts)
# =============================================================================
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
OPENROUTER_MODEL=openai/gpt-4o-mini

# =============================================================================
# Ports and Vite
# =============================================================================
# PORT: Express API (default 3001). Vite dev server proxies /api to this port.
PORT=3001

# DISABLE_HMR: set to true in hosted sandboxes (e.g. AI Studio) to turn off HMR/file watching.
# DISABLE_HMR=
