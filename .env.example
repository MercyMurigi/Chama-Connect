# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_API_KEY: Alternative env name for Gemini (BuiltInAgent).
GOOGLE_API_KEY=""

# LLM_PROVIDER: gemini | anthropic | openrouter (for /api/llm/* routes; CopilotKit BuiltInAgent uses gemini or anthropic).
LLM_PROVIDER="gemini"

# ANTHROPIC_API_KEY: For Claude via /api/llm and CopilotKit when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-haiku-20241022"

# OPENROUTER_API_KEY: OpenAI-compatible /api/llm only (REST).
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"

# OPENAI_API_KEY: Optional; CopilotKit BuiltInAgent if no Gemini/Anthropic keys.
OPENAI_API_KEY=""

# PORT: Express API (default 3001). Vite proxies /api → this port.
PORT="3001"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
